# VoxelCraft Desktop Application - Environment Variables
# =========================================================
# 
# This file contains example environment variables for the application.
# Copy this file to .env and fill in your actual values.
# NEVER commit .env with real credentials to version control!
# 
# For production, keys should be fetched from Supabase via SecretManager.
# These environment variables are for development/testing.

# ═══════════════════════════════════════════════════════════════
# RAZORPAY PAYMENT GATEWAY CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Get these from your Razorpay Dashboard > Settings > API Keys
# Test keys start with 'rzp_test_', Live keys start with 'rzp_live_'

RAZORPAY_KEY_ID=rzp_test_YourTestKeyIdHere
RAZORPAY_KEY_SECRET=YourTestKeySecretHere
RAZORPAY_WEBHOOK_SECRET=YourWebhookSecretHere

# ═══════════════════════════════════════════════════════════════
# OTHER PAYMENT PROVIDERS (if needed)
# ═══════════════════════════════════════════════════════════════
# Gumroad
# GUMROAD_ACCESS_TOKEN=your_gumroad_access_token

# Stripe
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# LemonSqueezy
# LEMONSQUEEZY_API_KEY=your_api_key
# LEMONSQUEEZY_STORE_ID=your_store_id

# Cashfree
# CASHFREE_APP_ID=your_app_id
# CASHFREE_SECRET_KEY=your_secret_key

# UPI (Manual)
# UPI_ID=yourname@upi

# ═══════════════════════════════════════════════════════════════
# SUPABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# ═══════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════
# DEBUG=true
# LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════
# SECURITY NOTES
# ═══════════════════════════════════════════════════════════════
# 1. NEVER commit this file with real credentials to Git
# 2. In production, keys are fetched securely via SecretManager
# 3. SecretManager provides 3-tier security:
#    - Environment variables (for development)
#    - Local cache (after first fetch)
#    - Remote Supabase RPC (requires valid license)
# 4. Keys are encrypted in transit and at rest
# 5. Tampering is detected via signature verification
# ═══════════════════════════════════════════════════════════════
